# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# OpenSearch Configuration
# ============================================================================
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=MySecurePassword123!
OPENSEARCH_SCHEME=https
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_NAME=companies

# ============================================================================
# OpenAI / Azure OpenAI Configuration
# ============================================================================

# For OpenAI
OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo

# For Azure OpenAI (enable by setting API_BASE to Azure endpoint)
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_API_BASE=https://your-resource.openai.azure.com/
# OPENAI_API_VERSION=2024-02-15-preview
# OPENAI_DEPLOYMENT_NAME=gpt-4-deployment

OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSION=8192

# ============================================================================
# Claude Configuration (Optional)
# ============================================================================
ANTHROPIC_API_KEY=your-claude-api-key-here

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://firmable_user:password123@localhost:5432/firmable_search
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
CACHE_ENABLED=true

# ============================================================================
# Search Features
# ============================================================================
ENABLE_SEMANTIC_SEARCH=true
ENABLE_AGENTIC_SEARCH=true
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_CACHING=true

# ============================================================================
# Performance Settings
# ============================================================================
MAX_CONCURRENT_OPENSEARCH_REQUESTS=50
MAX_CONCURRENT_LLM_REQUESTS=10
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_OPENAI_REQUESTS_PER_MINUTE=1800
